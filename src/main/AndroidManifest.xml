<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="net.localhost.sniffer"
    android:versionCode="2"
    android:versionName="1.2">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- API25以下のランチャー向け旧ショートカット作成 -->
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />

    <application
        android:name=".App"
        android:label="Sniffer"
        android:icon="@android:drawable/ic_menu_save"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden"
            android:supportsPictureInPicture="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
            </intent-filter>
        </activity>

        <!-- PWA standalone窓: ショートカットのdata URLごとに独立タスク（同一URLは既存タスク再利用） -->
        <activity
            android:name=".PwaActivity"
            android:exported="true"
            android:label="PWA"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden"
            android:supportsPictureInPicture="true"
            android:documentLaunchMode="intoExisting"
            android:autoRemoveFromRecents="false" />

        <!-- 検索ウィジェットのバーから開く検索オーバーレイ（ホーム上に重なる） -->
        <activity
            android:name=".SearchActivity"
            android:exported="true"
            android:theme="@style/SearchOverlay"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <!-- 検索ウィジェットの音声検索（透明・即終了） -->
        <activity
            android:name=".VoiceSearchActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true" />

        <!-- ホーム画面ウィジェット: 検索バー -->
        <receiver
            android:name=".SearchWidget"
            android:exported="true"
            android:label="Gobie 検索">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/search_widget_info" />
        </receiver>

        <!-- ホーム画面ウィジェット: 固定サイトの新着記事リスト -->
        <receiver
            android:name=".ArticleWidget"
            android:exported="true"
            android:label="Gobie 新着記事">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="net.localhost.sniffer.ARTICLE_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/articles_widget_info" />
        </receiver>

        <service
            android:name=".ArticleWidgetService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <service
            android:name=".DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <service
            android:name=".HeadlessBrowserService"
            android:exported="true"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
